{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "declaration": false,
    "paths": {
      "@animus-ui/core": ["../core/src"],
      "@animus-ui/core/*": ["../core/src/*"],
      "@animus-ui/runtime": ["../runtime/src"],
      "@animus-ui/runtime/*": ["../runtime/src/*"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
