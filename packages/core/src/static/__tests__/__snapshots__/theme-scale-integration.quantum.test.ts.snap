exports[`Theme Scale Integration > should resolve theme tokens using prop scales from groups 1`] = `
"/* Base Styles */
.animus-Card-c4d {
  padding: 1rem;
  background-color: background.elevated;
}

/* Atomic Utilities from Groups */
/* Group: color */
.animus-c-textprimary {
  color: var(--animus-colors-text-primary);
}
.animus-bg-primary {
  background-color: var(--animus-colors-primary);
}
/* Group: space */
.animus-m-sm {
  margin: sm;
}
@media screen and (min-width: 480px) {
  .animus-m-md-xs {
    margin: md;
  }
}
@media screen and (min-width: 768px) {
  .animus-m-lg-sm {
    margin: lg;
  }
}
.animus-p-md {
  padding: md;
}"
`;
