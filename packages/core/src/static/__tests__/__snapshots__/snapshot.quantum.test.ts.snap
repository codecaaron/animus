  display: flex;
  flex-direction: column;
  width: 100%;
}

/* Base Styles */
.animus-TabsList-t8t {
  border-bottom: 2px solid #e0e0e0;
  overflow: auto;
  display: flex;
  scrollbar-width: none;
}
.animus-TabsList-t8t::-webkit-scrollbar {
  display: none;
}

/* Variant: variant="pills" */
.animus-TabsList-t8t-variant-pills {
  border-bottom: none;
  gap: 8px;
  padding: 4px;
  background-color: #f0f0f0;
  border-radius: 8px;
}

/* Base Styles */
.animus-TabsTrigger-t11r {
  padding: 12px 24px;
  border: none;
  border-bottom: 2px solid transparent;
  transition: all 0.2s ease;
  background-color: transparent;
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  color: #666;
  margin-bottom: -2px;
  white-space: nowrap;
}
