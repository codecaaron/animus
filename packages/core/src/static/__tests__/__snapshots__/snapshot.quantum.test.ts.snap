exports[`[QUANTUM] Animus Static Extraction Integration > generates CSS for animation-heavy component > animated-card-integration 1`] = `
{
  "allCSS": "/* Base Styles */
.animus-AnimatedCard-a12d {
  padding: 24px;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  position: relative;
  background-color: white;
  border-radius: 12px;
  cursor: pointer;
}
.animus-AnimatedCard-a12d::before {
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  transition: left 0.5s ease;
  content: "";
  position: absolute;
  top: 0px;
  left: -100%;
  width: 100%;
  height: 100%;
}
.animus-AnimatedCard-a12d:hover {
  transform: scale(1.02);
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}
.animus-AnimatedCard-a12d:hover::before {
  left: 100%;
}
.animus-AnimatedCard-a12d:active {
  transform: scale(0.98);
}

/* State: loading */
.animus-AnimatedCard-a12d-state-loading {
  pointer-events: none;
}
.animus-AnimatedCard-a12d-state-loading::after {
  margin: -12px 0 0 -12px;
  border: 2px solid #f3f3f3;
  border-top: 2px solid #3498db;
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}",
  "components": [
    {
