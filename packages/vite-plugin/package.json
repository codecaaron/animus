{
  "name": "@animus-ui/vite-plugin",
  "version": "0.1.1",
  "description": "Animus static CSS extraction Vite plugin",
  "keywords": [
    "animus",
    "css",
    "css-in-js",
    "styled",
    "vite",
    "vite-plugin",
    "zero-runtime"
  ],
  "homepage": "https://github.com/codecaaron/animus/tree/main/packages/vite-plugin#readme",
  "license": "MIT",
  "author": "codecaaron <airrobb@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecaaron/animus",
    "directory": "packages/vite-plugin"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build:ts",
    "build:ts": "tsdown && tsgo -p tsconfig.build.json",
    "compile": "tsgo --noEmit"
  },
  "dependencies": {
    "@animus-ui/extract": "workspace:*",
    "browserslist": "^4.24.0",
    "lightningcss": "^1.29.0"
  },
  "peerDependencies": {
    "@mdx-js/mdx": "^3.0.0",
    "vite": ">=8 <9"
  },
  "peerDependenciesMeta": {
    "@mdx-js/mdx": {
      "optional": true
    }
  }
}
