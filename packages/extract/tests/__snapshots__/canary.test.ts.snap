exports[`Snapshot Layer 1: Styles + Variants CSS matches snapshot 1`] = `
"@layer base, variants, states, system, custom;

@layer base {
  .animus-ButtonContainer-2d24b9a6 {
    align-items: center;
    border: none;
    border-radius: 4px;
    box-shadow: none;
    cursor: pointer;
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    letter-spacing: 1px;
    line-height: calc(2px + 2.8ex + 2px);
    padding: 0;
    position: relative;
    user-select: none;
  }
}

@layer variants {
  .animus-ButtonContainer-2d24b9a6--variant-fill {
    background-position: 0% 0%;
    background-size: 300px 100%;
    background-color: transparent;
    color: var(--colors-background);
    background-image: var(--gradients-flowX);
    transition: 500ms ease background-position;
  }
  .animus-ButtonContainer-2d24b9a6--variant-fill:hover {
    background-position: -100px 0%;
  }
  .animus-ButtonContainer-2d24b9a6--variant-stroke::before {
    border-radius: 4px;
    content: "";
    position: absolute;
  }
  .animus-ButtonForeground-3e38f3b1--size-lg {
    font-size: 1.375rem;
    line-height: 48px;
    min-height: 48px;
    min-width: 100px;
    padding-bottom: 0.125rem;
    padding-left: 2rem;
    padding-right: 2rem;
  }
  .animus-ButtonForeground-3e38f3b1--size-sm {
    font-size: 0.875rem;
    line-height: 26px;
    min-height: 28px;
    min-width: 60px;
    padding-bottom: 0.125rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }
  .animus-ButtonForeground-3e38f3b1--variant-stroke {
    position: relative;
    user-select: none;
    z-index: 1;
  }
}

"
`;

