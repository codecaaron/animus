{
  "name": "@animus-ui/extract",
  "version": "0.1.0",
  "description": "Animus static CSS extraction pipeline (Rust/NAPI)",
  "author": "codecaaron <airrobb@gmail.com>",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js"
    },
    "./pipeline": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": ["index.js", "index.d.ts", "*.node", "dist"],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecaaron/animus"
  },
  "napi": {
    "binaryName": "animus-extract",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release && tsdown && tsc -p tsconfig.build.json",
    "build:debug": "napi build --platform",
    "build:pipeline": "tsdown && tsc -p tsconfig.build.json"
  },
  "optionalDependencies": {
    "@animus-ui/extract-darwin-arm64": "0.1.0",
    "@animus-ui/extract-linux-x64-gnu": "0.1.0",
    "@animus-ui/extract-linux-arm64-gnu": "0.1.0"
  },
  "devDependencies": {
    "@animus-ui/system": "workspace:*",
    "@napi-rs/cli": "^3.0.0"
  }
}
