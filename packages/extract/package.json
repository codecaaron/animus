{
  "name": "@animus-ui/extract",
  "version": "0.1.1",
  "description": "Animus static CSS extraction pipeline (Rust/NAPI)",
  "keywords": [
    "animus",
    "compiler",
    "css",
    "css-in-js",
    "napi",
    "rust",
    "static-css",
    "zero-runtime"
  ],
  "homepage": "https://github.com/codecaaron/animus/tree/main/packages/extract#readme",
  "license": "MIT",
  "author": "codecaaron <airrobb@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecaaron/animus",
    "directory": "packages/extract"
  },
  "files": [
    "dist",
    "index-v2.js",
    "index-v2.d.ts",
    "crates/extract-v2/*.node",
    "crates/extract-v2/index.d.ts"
  ],
  "main": "index-v2.js",
  "types": "index-v2.d.ts",
  "exports": {
    ".": {
      "import": "./index-v2.js",
      "require": "./index-v2.js",
      "default": "./index-v2.js"
    },
    "./pipeline": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build:v2 && bun run build:ts",
    "build:ts": "tsdown && tsc -p tsconfig.build.json",
    "compile": "tsc -p tsconfig.build.json --noEmit",
    "build:v2": "cd crates/extract-v2 && bunx napi build --platform --release",
    "build:v2:debug": "cd crates/extract-v2 && bunx napi build --platform"
  },
  "dependencies": {
    "@animus-ui/properties": "workspace:*"
  },
  "devDependencies": {
    "@animus-ui/system": "workspace:*",
    "@mdx-js/mdx": "3.1.1",
    "@napi-rs/cli": "^3.7.3"
  },
  "peerDependencies": {
    "@mdx-js/mdx": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@mdx-js/mdx": {
      "optional": true
    }
  }
}
