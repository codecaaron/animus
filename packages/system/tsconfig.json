{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "__tests__/**/*.test-d.ts",
    "__tests__/**/*.test-d.tsx"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
