{
  "name": "@animus-ui/showcase",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "verify:build": "bash ../../scripts/verify/build-consumer.sh",
    "verify:assert": "bash ../../scripts/verify/assert-consumer.sh packages/showcase/dist scripts/assert-showcase-build.ts",
    "verify:dry-run": "bash ../../scripts/verify/dry-run-worker.sh packages/showcase '@animus-ui/showcase' packages/showcase/dist animus '@animus-ui/showcase#verify:build'",
    "verify": "vp run @animus-ui/showcase#verify:build && vp run @animus-ui/showcase#verify:assert && vp run @animus-ui/showcase#verify:dry-run",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "compile": "tsgo --noEmit",
    "cf:deploy": "wrangler deploy",
    "cf:upload": "wrangler versions upload",
    "cf:dry-run": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@animus-ui/system": "workspace:*",
    "@animus-ui/test-ds": "workspace:*",
    "@animus-ui/vite-plugin": "workspace:*",
    "@ark-ui/react": "^5.35.0",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "lucide-react": "^1.7.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.1.4"
  }
}
