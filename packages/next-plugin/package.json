{
  "name": "@animus-ui/next-plugin",
  "version": "0.1.0",
  "description": "Animus static CSS extraction for Next.js (webpack)",
  "author": "codecaaron <airrobb@gmail.com>",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./loader": {
      "types": "./dist/loader.d.ts",
      "import": "./dist/loader.mjs",
      "require": "./dist/loader.cjs",
      "default": "./dist/loader.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/codecaaron/animus/tree/main/packages/next-plugin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecaaron/animus",
    "directory": "packages/next-plugin"
  },
  "keywords": [
    "next",
    "nextjs",
    "webpack",
    "css",
    "css-in-js",
    "zero-runtime",
    "styled",
    "animus"
  ],
  "scripts": {
    "build": "bun run build:ts",
    "build:ts": "tsdown && tsc -p tsconfig.build.json",
    "compile": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mdx-js/mdx": "^3.0.0",
    "next": ">=14.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@mdx-js/mdx": {
      "optional": true
    }
  },
  "dependencies": {
    "@animus-ui/extract": "workspace:*"
  }
}
