{
  "name": "@animus-ui/next-plugin",
  "version": "0.1.0",
  "description": "Animus static CSS extraction for Next.js (webpack)",
  "keywords": [
    "animus",
    "css",
    "css-in-js",
    "next",
    "nextjs",
    "styled",
    "webpack",
    "zero-runtime"
  ],
  "homepage": "https://github.com/codecaaron/animus/tree/main/packages/next-plugin#readme",
  "license": "MIT",
  "author": "codecaaron <airrobb@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codecaaron/animus",
    "directory": "packages/next-plugin"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build:ts",
    "build:ts": "tsdown && tsgo -p tsconfig.build.json",
    "compile": "tsgo --noEmit"
  },
  "dependencies": {
    "@animus-ui/extract": "workspace:*"
  },
  "peerDependencies": {
    "@mdx-js/mdx": "^3.0.0",
    "next": ">=15 <16",
    "webpack": ">=5 <6"
  },
  "peerDependenciesMeta": {
    "@mdx-js/mdx": {
      "optional": true
    }
  }
}
