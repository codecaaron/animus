{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/_assertions",
    "packages/_integration",
    "packages/extract",
    "packages/next-plugin",
    "packages/properties",
    "packages/showcase",
    "packages/system",
    "packages/test-ds",
    "packages/vite-plugin",
    "e2e/next-app",
    "e2e/vite-app"
  ],
  "type": "module",
  "scripts": {
    "rebuild": "vp run clean:full && vp run build:all",
    "test": "bunx vp test run",
    "deploy:showcase": "vp run build:showcase && bunx netlify deploy --dir=packages/showcase/dist --prod",
    "dev:showcase": "bun run --filter './packages/showcase' dev",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "@animus-ui/assertions": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/lodash": "^4.14.178",
    "@types/node": "^18.15.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.2",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "csstype": "3.1.3",
    "happy-dom": "^20.8.9",
    "knip": "^6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsdown": "^0.21.4",
    "vite-plus": "0.1.20",
    "vitest": "^4.1.5"
  },
  "packageManager": "bun@1.3.13"
}
