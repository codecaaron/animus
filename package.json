{
  "name": "root",
  "private": true,
  "workspaces": [
    "packages/_assertions",
    "packages/_integration",
    "packages/extract",
    "packages/next-plugin",
    "packages/properties",
    "packages/showcase",
    "packages/system",
    "packages/test-ds",
    "packages/vite-plugin",
    "e2e/next-app",
    "e2e/vite-app"
  ],
  "scripts": {
    "clean": "rm -rf packages/*/dist packages/extract/target",
    "clean:light": "rm -rf node_modules/.vite packages/*/dist",
    "clean:full": "rm -rf node_modules/.vite packages/*/dist packages/extract/target packages/extract/*.node",
    "rebuild": "bun run clean:full && vp run build:all",
    "test": "bun test",
    "compile": "bun run --filter './packages/*' compile",
    "lint": "biome check --linter-enabled=true --formatter-enabled=false",
    "format": "biome check --linter-enabled=false --formatter-enabled=true",
    "check": "biome check",
    "check:fix": "biome check --write",
    "verify:compile:tsc-fallback": "bun run --filter './packages/*' compile:tsc-fallback",
    "deploy:showcase": "vp run build:showcase && bunx netlify deploy --dir=packages/showcase/dist --prod",
    "dev:showcase": "bun run --filter './packages/showcase' dev",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {
    "@animus-ui/assertions": "workspace:*",
    "@biomejs/biome": "2.4.9",
    "@types/bun": "^1.3.11",
    "@types/lodash": "^4.14.178",
    "@types/node": "^18.15.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.2",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "csstype": "3.1.3",
    "knip": "^6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsdown": "^0.21.4",
    "typescript": "6.0.3",
    "vite-plus": "0.1.20"
  },
  "packageManager": "bun@1.3.13"
}
