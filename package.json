{
  "name": "root",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter './packages/core' build && bun run --filter './packages/theming' build && bun run --filter './packages/ui' build",
    "test": "bun test",
    "compile": "tsc --noEmit",
    "lint": "biome check --linter-enabled=true --formatter-enabled=false",
    "format": "biome check --linter-enabled=false --formatter-enabled=true",
    "check": "biome check",
    "check:fix": "biome check --write",
    "verify": "bun run compile && bun run check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@types/lodash": "^4.14.178",
    "@types/node": "^18.15.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.2",
    "@types/stylis": "^4.2.7",
    "csstype": "3.1.3",
    "lodash": "4.17.21",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tsdown": "^0.21.4",
    "typescript": "5.8.3"
  }
}
